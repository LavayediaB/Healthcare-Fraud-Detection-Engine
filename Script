import pandas as pd

# STEP 1. Loading the dataset into python
file_name = 'Train_Inpatientdata-1542865627584.csv'
df = pd.read_csv(file_name)

print("--- Data Integrity Audit: Inpatient Claims ---")

# STEP 2. Checking for null values to ensure that the data is complete and clean
missing = df[['BeneID', 'ClaimID', 'Provider', 'InscClaimAmtReimbursed']].isnull().sum()
print("\nMissing Values in Core Fields:")
print(missing)

# STEP 3. Identify "Zero-Reimbursement" claims where there is no insurance payout despite the patient being admitted
invalid_financials = df[df['InscClaimAmtReimbursed'] <= 0]
print(f"\nFlagged {len(invalid_financials)} records with zero or negative reimbursement.")

# STEP 4. Finding billing anomalies. We aim to determine if the same patient and provider had two different claims on the same date
duplicates = df[df.duplicated(subset=['BeneID', 'Provider', 'ClaimStartDt'], keep=False)]
print(f"Flagged {len(duplicates)} potential duplicate/overlapping claims.")

# STEP 5. Exporting our findings
if len(duplicates) > 0:
    duplicates.to_csv('audit_report_duplicates.csv', index=False)
    print("\nSUCCESS: Anomaly report saved to 'audit_report_duplicates.csv'")

    
print("\n--- Running Statistical Risk Profile ---")

# STEP 6. Calculate the 'Normal' range for reimbursements
mean_reimb = df['InscClaimAmtReimbursed'].mean()
std_reimb = df['InscClaimAmtReimbursed'].std()
threshold = mean_reimb + (3 * std_reimb)

print(f"Average Reimbursement: R{mean_reimb:,.2f}")
print(f"High-Risk Threshold (3 Std Dev): R{threshold:,.2f}")

# STEP 7. Identify the Outliers for reimbursement
outliers = df[df['InscClaimAmtReimbursed'] > threshold]

print(f"\nFlagged {len(outliers)} claims as 'Extreme Outliers' (Over R{threshold:,.2f})")

# STEP 8. Analyze the Top 5 most expensive reimbursement claims
print("\nTop 5 Most Expensive Claims (High Priority):")
print(outliers[['BeneID', 'ClaimID', 'Provider', 'InscClaimAmtReimbursed']].sort_values(by='InscClaimAmtReimbursed', ascending=False).head())

# STEP 9. Export these for the Fraud Investigation Team to further analyse
outliers.to_csv('high_priority_risk_claims.csv', index=False)
print("\nSUCCESS: Risk report saved to 'high_priority_risk_claims.csv'")

# --- PROVIDER RISK PROFILING ---

print("\n--- Identifying High-Risk Providers ---")

# STEP 10. Group by Provider and calculate total stats so we can analyse Total reimbursed, Count of claims, and Average per claim
provider_analysis = df.groupby('Provider')['InscClaimAmtReimbursed'].agg(['sum', 'count', 'mean']).reset_index()

provider_analysis.columns = ['Provider_ID', 'Total_Reimbursed', 'Claim_Count', 'Avg_Claim_Amount']

# STEP 11. Find providers who have more than 50 claims and an Average Claim Amount above our 3- STD deviation Threshold
high_risk_providers = provider_analysis[provider_analysis['Avg_Claim_Amount'] > 20000].sort_values(by='Total_Reimbursed', ascending=False)

print("\nTop 5 Providers by Total Financial Impact:")
print(high_risk_providers.head())

# STEP 12. Save this list for the Management Report to analyse further
high_risk_providers.to_csv('provider_risk_profile.csv', index=False)
print("\nSUCCESS: Provider risk profiles saved to 'provider_risk_profile.csv'")

import matplotlib.pyplot as plt
import seaborn as sns

# --- RISK VISUALIZATION ---

print("\n--- Generating Risk Visualization ---")

plt.figure(figsize=(12, 7))
sns.set_style("whitegrid")

# Create the scatter plot to plot Number of Claims vs Total Money
scatter = sns.scatterplot(
    data=provider_analysis, 
    x='Claim_Count', 
    y='Total_Reimbursed', 
    alpha=0.6, 
    color='skyblue'
)

# Highlight the top-risk provider (PRV51067) in Red
top_risk = provider_analysis[provider_analysis['Provider_ID'] == 'PRV51067']
plt.scatter(
    top_risk['Claim_Count'], 
    top_risk['Total_Reimbursed'], 
    color='red', 
    s=100, 
    label='High-Risk Target (PRV51067)'
)


plt.title('Provider Risk Analysis: Volume vs. Financial Impact', fontsize=15)
plt.xlabel('Total Number of Claims', fontsize=12)
plt.ylabel('Total Reimbursed Amount (Millions)', fontsize=12)
plt.legend()

plt.savefig('healthcare_risk_analysis.png')
print("SUCCESS: Visualization saved as 'healthcare_risk_analysis.png'")

plt.show()
